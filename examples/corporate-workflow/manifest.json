{
  "name": "CWF.Corporate workflow application test model",
  "application": {
    "rootCategoryPath": "K2 Skills\\CWF.Corporate Workflow"
  },
  "database": {
    "server": "localhost",
    "name": "CWF.CorporateWorkflowTest",
    "integratedSecurity": true,
    "createIfMissing": true,
    "commandTimeoutSeconds": 120,
    "runtimePrincipal": "TRIALS\\k2svc",
    "scripts": [
      "sql/001_schemas_and_reference_data.sql",
      "sql/002_workflow_model.sql",
      "sql/003_views_procedures_and_test_data.sql"
    ]
  },
  "k2": {
    "host": "localhost",
    "port": 5555,
    "integrated": true,
    "securityLabel": "K2",
    "serviceInstance": {
      "systemName": "CWF.CorporateWorkflowTest",
      "displayName": "CWF.Corporate Workflow Test",
      "description": "Disposable corporate workflow SQL SmartObject test model",
      "authenticationMode": "service-account",
      "commandTimeoutSeconds": 30,
      "useNativeSqlExecution": true,
      "useSqlPaging": false,
      "encryptConnection": false,
      "onDifferentSqlServer": false
    },
    "smartObjects": {
      "createNew": true,
      "updateExisting": true,
      "deleteRemoved": false
    }
  },
  "approvalMatrices": [
    {
      "name": "CWF.Request approval matrix",
      "schema": "CWF",
      "table": "RequestApprovalMatrix",
      "resolverProcedure": "ResolveRequestApproval",
      "matrixCode": "CWF.REQUEST",
      "dimensions": [
        { "name": "DepartmentId", "type": "number" }
      ],
      "rules": [
        {
          "key": "DEFAULT-STAGE-1",
          "stage": 1,
          "minAmount": 0,
          "priority": 100,
          "approverType": "User",
          "approver": "$designer",
          "approverLabel": "Default Manager"
        },
        {
          "key": "HR-MANAGER",
          "stage": 1,
          "minAmount": 0,
          "maxAmount": 1000,
          "priority": 10,
          "conditions": { "DepartmentId": 1 },
          "approverType": "User",
          "approver": "$designer",
          "approverLabel": "HR Manager"
        },
        {
          "key": "HR-DIRECTOR",
          "stage": 1,
          "minAmount": 1000,
          "priority": 10,
          "conditions": { "DepartmentId": 1 },
          "approverType": "User",
          "approver": "$designer",
          "approverLabel": "HR Director"
        },
        {
          "key": "EXECUTIVE-STAGE-2",
          "stage": 2,
          "minAmount": 5000,
          "priority": 10,
          "approverType": "User",
          "approver": "$designer",
          "approverLabel": "Executive Approver"
        }
      ]
    }
  ],
  "verification": {
    "sqlObjects": [
      { "type": "table", "schema": "CWF", "name": "Department" },
      { "type": "table", "schema": "CWF", "name": "Employee" },
      { "type": "table", "schema": "CWF", "name": "RequestType" },
      { "type": "table", "schema": "CWF", "name": "RequestPriority" },
      { "type": "table", "schema": "CWF", "name": "RequestStatus" },
      { "type": "table", "schema": "CWF", "name": "ApprovalTaskStatus" },
      { "type": "table", "schema": "CWF", "name": "ApprovalDecision" },
      { "type": "table", "schema": "CWF", "name": "WorkflowRequest" },
      { "type": "table", "schema": "CWF", "name": "ApprovalTask" },
      { "type": "table", "schema": "CWF", "name": "RequestComment" },
      { "type": "view", "schema": "CWF", "name": "RequestSummary" },
      { "type": "view", "schema": "CWF", "name": "ApprovalInbox" },
      { "type": "procedure", "schema": "CWF", "name": "WorkflowRequest_Submit" },
      { "type": "procedure", "schema": "CWF", "name": "ApprovalTask_Decide" },
      { "type": "procedure", "schema": "CWF", "name": "WorkflowDashboard" }
    ],
    "queries": [
      {
        "name": "CWF.Reference departments seeded",
        "sql": "SELECT COUNT(*) FROM CWF.Department",
        "expectedScalar": "4"
      },
      {
        "name": "CWF.Test request exists",
        "sql": "SELECT COUNT(*) FROM CWF.WorkflowRequest WHERE RequestNumber = N'CWF-TEST-0001'",
        "expectedScalar": "1"
      },
      {
        "name": "CWF.Pending approval exists",
        "sql": "SELECT COUNT(*) FROM CWF.ApprovalTask WHERE RequestId = (SELECT RequestId FROM CWF.WorkflowRequest WHERE RequestNumber = N'CWF-TEST-0001') AND Status = N'Pending'",
        "expectedScalar": "1"
      },
      {
        "name": "CWF.Lookup values seeded",
        "sql": "SELECT (SELECT COUNT(*) FROM CWF.RequestPriority) + (SELECT COUNT(*) FROM CWF.RequestStatus) + (SELECT COUNT(*) FROM CWF.ApprovalTaskStatus) + (SELECT COUNT(*) FROM CWF.ApprovalDecision)",
        "expectedScalar": "15"
      },
      {
        "name": "CWF.Lookup foreign keys enforced",
        "sql": "SELECT COUNT(*) FROM sys.foreign_keys WHERE parent_object_id IN (OBJECT_ID(N'CWF.WorkflowRequest'), OBJECT_ID(N'CWF.ApprovalTask')) AND name IN (N'FK_WorkflowRequest_Priority', N'FK_WorkflowRequest_Status', N'FK_ApprovalTask_Status', N'FK_ApprovalTask_Decision')",
        "expectedScalar": "4"
      }
    ],
    "minimumGeneratedSmartObjects": 15,
    "smartObjectServiceObjects": [
      "CWF-Department",
      "CWF-Employee",
      "CWF-RequestType",
      "CWF-RequestPriority",
      "CWF-RequestStatus",
      "CWF-ApprovalTaskStatus",
      "CWF-ApprovalDecision",
      "CWF-WorkflowRequest",
      "CWF-ApprovalTask",
      "CWF-RequestComment",
      "CWF-RequestSummary",
      "CWF-ApprovalInbox",
      "CWF-WorkflowRequest_Submit",
      "CWF-ApprovalTask_Decide",
      "CWF-WorkflowDashboard"
    ],
    "smokeTestListMethods": true
  }
}
