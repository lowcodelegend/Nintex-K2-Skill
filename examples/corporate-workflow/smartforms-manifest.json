{
  "name": "Corporate workflow CRUD SmartForms",
  "k2": {
    "host": "localhost",
    "port": 5555,
    "integrated": true,
    "securityLabel": "K2"
  },
  "application": {
    "rootCategoryPath": "K2 Skills\\Corporate Workflow",
    "theme": "Lithium",
    "replaceExisting": true,
    "checkIn": true,
    "views": [
      {
        "name": "CW Request Editor",
        "smartObject": "K2Skills_CorporateWorkflow_Test_app_WorkflowRequest",
        "type": "capture",
        "properties": [
          "RequestId",
          "RequestNumber",
          "RequestTypeId",
          "RequestorEmployeeId",
          "DepartmentId",
          "Title",
          "Description",
          "Amount",
          "Priority",
          "Status",
          "SubmittedOn",
          "CompletedOn"
        ],
        "methods": ["Create", "Read", "Update", "Delete"],
        "options": ["editable", "labels-left", "colon-labels", "toolbar"]
      },
      {
        "name": "CW Request List",
        "smartObject": "K2Skills_CorporateWorkflow_Test_app_WorkflowRequest",
        "type": "list",
        "properties": [
          "RequestId",
          "RequestNumber",
          "Title",
          "Amount",
          "Priority",
          "Status",
          "SubmittedOn",
          "CreatedOn"
        ],
        "methods": [],
        "defaultListMethod": "List",
        "options": ["toolbar"]
      },
      {
        "name": "CW Approval Task Editor",
        "smartObject": "K2Skills_CorporateWorkflow_Test_app_ApprovalTask",
        "type": "capture",
        "properties": [
          "ApprovalTaskId",
          "RequestId",
          "StepNumber",
          "StepName",
          "AssignedEmployeeId",
          "Status",
          "Decision",
          "DecisionComment",
          "DueOn",
          "ActedOn"
        ],
        "methods": ["Create", "Read", "Update", "Delete"],
        "options": ["editable", "labels-left", "colon-labels", "toolbar"]
      },
      {
        "name": "CW Approval Task List",
        "smartObject": "K2Skills_CorporateWorkflow_Test_app_ApprovalTask",
        "type": "list",
        "properties": [
          "ApprovalTaskId",
          "RequestId",
          "StepNumber",
          "StepName",
          "AssignedEmployeeId",
          "Status",
          "Decision",
          "DueOn"
        ],
        "methods": [],
        "defaultListMethod": "List",
        "options": ["toolbar"]
      },
      {
        "name": "CW Request Type Editor",
        "smartObject": "K2Skills_CorporateWorkflow_Test_app_RequestType",
        "type": "capture",
        "properties": [
          "RequestTypeId",
          "RequestTypeCode",
          "RequestTypeName",
          "Description",
          "DefaultSlaHours",
          "RequiresAmount",
          "IsActive"
        ],
        "methods": ["Create", "Read", "Update", "Delete"],
        "options": ["editable", "labels-left", "colon-labels", "toolbar"]
      },
      {
        "name": "CW Request Type List",
        "smartObject": "K2Skills_CorporateWorkflow_Test_app_RequestType",
        "type": "list",
        "properties": [
          "RequestTypeId",
          "RequestTypeCode",
          "RequestTypeName",
          "DefaultSlaHours",
          "RequiresAmount",
          "IsActive"
        ],
        "methods": [],
        "defaultListMethod": "List",
        "options": ["toolbar"]
      }
    ],
    "forms": [
      {
        "name": "CW Request Management",
        "views": ["CW Request Editor", "CW Request List"],
        "options": ["no-tabs"],
        "behaviors": ["load-form-list-click", "refresh-list-form-submit", "refresh-list-form-load"]
      },
      {
        "name": "CW Approval Task Management",
        "views": ["CW Approval Task Editor", "CW Approval Task List"],
        "options": ["no-tabs"],
        "behaviors": ["load-form-list-click", "refresh-list-form-submit", "refresh-list-form-load"]
      },
      {
        "name": "CW Request Type Administration",
        "views": ["CW Request Type Editor", "CW Request Type List"],
        "options": ["no-tabs"],
        "behaviors": ["load-form-list-click", "refresh-list-form-submit", "refresh-list-form-load"]
      }
    ]
  },
  "verification": {
    "expectedViews": [
      "CW Request Editor",
      "CW Request List",
      "CW Approval Task Editor",
      "CW Approval Task List",
      "CW Request Type Editor",
      "CW Request Type List"
    ],
    "expectedForms": [
      "CW Request Management",
      "CW Approval Task Management",
      "CW Request Type Administration"
    ],
    "smokeTestRuntime": true,
    "runtimeBaseUrl": "https://spk2.trials.demome.tech/Runtime"
  }
}
