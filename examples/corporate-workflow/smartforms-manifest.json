{
  "name": "CWF.Corporate workflow CRUD SmartForms",
  "k2": {
    "host": "localhost",
    "port": 5555,
    "integrated": true,
    "securityLabel": "K2"
  },
  "application": {
    "rootCategoryPath": "K2 Skills\\CWF.Corporate Workflow",
    "theme": "Lithium",
    "replaceExisting": true,
    "checkIn": true,
    "views": [
      {
        "name": "CWF.Request Editor",
        "smartObject": "CWF.CorporateWorkflowTest_CWF_WorkflowRequest",
        "type": "capture",
        "properties": [
          "RequestId",
          "RequestNumber",
          "RequestTypeId",
          "RequestorEmployeeId",
          "DepartmentId",
          "Title",
          "Description",
          "Amount",
          "Priority",
          "Status",
          "SubmittedOn",
          "CompletedOn"
        ],
        "methods": ["Create", "Read", "Update", "Delete"],
        "options": ["editable", "labels-left", "colon-labels", "toolbar"]
      },
      {
        "name": "CWF.Request List",
        "smartObject": "CWF.CorporateWorkflowTest_CWF_WorkflowRequest",
        "type": "list",
        "properties": [
          "RequestId",
          "RequestNumber",
          "Title",
          "Amount",
          "Priority",
          "Status",
          "SubmittedOn",
          "CreatedOn"
        ],
        "methods": [],
        "defaultListMethod": "List",
        "options": ["toolbar"]
      },
      {
        "name": "CWF.Approval Task Editor",
        "smartObject": "CWF.CorporateWorkflowTest_CWF_ApprovalTask",
        "type": "capture",
        "properties": [
          "ApprovalTaskId",
          "RequestId",
          "StepNumber",
          "StepName",
          "AssignedEmployeeId",
          "Status",
          "Decision",
          "DecisionComment",
          "DueOn",
          "ActedOn"
        ],
        "methods": ["Create", "Read", "Update", "Delete"],
        "options": ["editable", "labels-left", "colon-labels", "toolbar"]
      },
      {
        "name": "CWF.Approval Task List",
        "smartObject": "CWF.CorporateWorkflowTest_CWF_ApprovalTask",
        "type": "list",
        "properties": [
          "ApprovalTaskId",
          "RequestId",
          "StepNumber",
          "StepName",
          "AssignedEmployeeId",
          "Status",
          "Decision",
          "DueOn"
        ],
        "methods": [],
        "defaultListMethod": "List",
        "options": ["toolbar"]
      },
      {
        "name": "CWF.Request Type Editor",
        "smartObject": "CWF.CorporateWorkflowTest_CWF_RequestType",
        "type": "capture",
        "properties": [
          "RequestTypeId",
          "RequestTypeCode",
          "RequestTypeName",
          "Description",
          "DefaultSlaHours",
          "RequiresAmount",
          "IsActive"
        ],
        "methods": ["Create", "Read", "Update", "Delete"],
        "options": ["editable", "labels-left", "colon-labels", "toolbar"]
      },
      {
        "name": "CWF.Request Type List",
        "smartObject": "CWF.CorporateWorkflowTest_CWF_RequestType",
        "type": "list",
        "properties": [
          "RequestTypeId",
          "RequestTypeCode",
          "RequestTypeName",
          "DefaultSlaHours",
          "RequiresAmount",
          "IsActive"
        ],
        "methods": [],
        "defaultListMethod": "List",
        "options": ["toolbar"]
      }
    ],
    "forms": [
      {
        "name": "CWF.Request Management",
        "views": ["CWF.Request Editor", "CWF.Request List"],
        "options": ["no-tabs"],
        "behaviors": ["load-form-list-click", "refresh-list-form-submit", "refresh-list-form-load"]
      },
      {
        "name": "CWF.Approval Task Management",
        "views": ["CWF.Approval Task Editor", "CWF.Approval Task List"],
        "options": ["no-tabs"],
        "behaviors": ["load-form-list-click", "refresh-list-form-submit", "refresh-list-form-load"]
      },
      {
        "name": "CWF.Request Type Administration",
        "views": ["CWF.Request Type Editor", "CWF.Request Type List"],
        "options": ["no-tabs"],
        "behaviors": ["load-form-list-click", "refresh-list-form-submit", "refresh-list-form-load"]
      }
    ]
  },
  "verification": {
    "expectedViews": [
      "CWF.Request Editor",
      "CWF.Request List",
      "CWF.Approval Task Editor",
      "CWF.Approval Task List",
      "CWF.Request Type Editor",
      "CWF.Request Type List"
    ],
    "expectedForms": [
      "CWF.Request Management",
      "CWF.Approval Task Management",
      "CWF.Request Type Administration"
    ],
    "smokeTestRuntime": true,
    "runtimeBaseUrl": "https://spk2.trials.demome.tech/Runtime"
  }
}
