{
  "name": "CWF.Corporate workflow CRUD SmartForms",
  "k2": {
    "host": "localhost",
    "port": 5555,
    "integrated": true,
    "securityLabel": "K2"
  },
  "application": {
    "rootCategoryPath": "K2 Skills\\CWF.Corporate Workflow",
    "theme": "Lithium",
    "styleProfile": "PSF UX v1",
    "replaceExisting": true,
    "checkIn": true,
    "lookups": [
      {
        "name": "Request Type",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_RequestType",
        "method": "List",
        "valueProperty": "RequestTypeId",
        "displayProperty": "RequestTypeName",
        "adminForm": "CWF.Request Type Administration"
      },
      {
        "name": "Department",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_Department",
        "method": "List",
        "valueProperty": "DepartmentId",
        "displayProperty": "DepartmentName"
      },
      {
        "name": "Employee",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_Employee",
        "method": "List",
        "valueProperty": "EmployeeId",
        "displayProperty": "DisplayName"
      },
      {
        "name": "Request Priority",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_RequestPriority",
        "method": "List",
        "valueProperty": "PriorityCode",
        "displayProperty": "PriorityName",
        "adminForm": "CWF.Request Priority Administration"
      },
      {
        "name": "Request Status",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_RequestStatus",
        "method": "List",
        "valueProperty": "StatusCode",
        "displayProperty": "StatusName"
      },
      {
        "name": "Approval Task Status",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_ApprovalTaskStatus",
        "method": "List",
        "valueProperty": "StatusCode",
        "displayProperty": "StatusName"
      },
      {
        "name": "Approval Decision",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_ApprovalDecision",
        "method": "List",
        "valueProperty": "DecisionCode",
        "displayProperty": "DecisionName"
      }
    ],
    "views": [
      {
        "name": "CWF.Request Editor",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_WorkflowRequest",
        "type": "capture",
        "properties": [
          "RequestId",
          "RequestNumber",
          "RequestTypeId",
          "RequestorEmployeeId",
          "DepartmentId",
          "Title",
          "Description",
          "Amount",
          "Priority",
          "Status",
          "SubmittedOn",
          "CompletedOn"
        ],
        "methods": ["Create", "Read", "Update", "Delete"],
        "lookupControls": [
          { "property": "RequestTypeId", "lookup": "Request Type" },
          { "property": "RequestorEmployeeId", "lookup": "Employee" },
          { "property": "DepartmentId", "lookup": "Department" },
          { "property": "Priority", "lookup": "Request Priority" },
          { "property": "Status", "lookup": "Request Status" }
        ],
        "options": ["editable", "labels-left", "colon-labels", "toolbar"]
      },
      {
        "name": "CWF.Request List",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_WorkflowRequest",
        "type": "list",
        "properties": [
          "RequestId",
          "RequestNumber",
          "Title",
          "Amount",
          "Priority",
          "Status",
          "SubmittedOn",
          "CreatedOn"
        ],
        "methods": [],
        "defaultListMethod": "List",
        "options": ["toolbar"]
      },
      {
        "name": "CWF.Approval Task Editor",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_ApprovalTask",
        "type": "capture",
        "properties": [
          "ApprovalTaskId",
          "RequestId",
          "StepNumber",
          "StepName",
          "AssignedEmployeeId",
          "Status",
          "Decision",
          "DecisionComment",
          "DueOn",
          "ActedOn"
        ],
        "methods": ["Create", "Read", "Update", "Delete"],
        "lookupControls": [
          { "property": "AssignedEmployeeId", "lookup": "Employee" },
          { "property": "Status", "lookup": "Approval Task Status" },
          { "property": "Decision", "lookup": "Approval Decision", "allowEmptySelection": true }
        ],
        "options": ["editable", "labels-left", "colon-labels", "toolbar"]
      },
      {
        "name": "CWF.Approval Task List",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_ApprovalTask",
        "type": "list",
        "properties": [
          "ApprovalTaskId",
          "RequestId",
          "StepNumber",
          "StepName",
          "AssignedEmployeeId",
          "Status",
          "Decision",
          "DueOn"
        ],
        "methods": [],
        "defaultListMethod": "List",
        "options": ["toolbar"]
      },
      {
        "name": "CWF.Request Type Editor",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_RequestType",
        "type": "capture",
        "properties": [
          "RequestTypeId",
          "RequestTypeCode",
          "RequestTypeName",
          "Description",
          "DefaultSlaHours",
          "RequiresAmount",
          "IsActive"
        ],
        "methods": ["Create", "Read", "Update", "Delete"],
        "area": "admin",
        "options": ["editable", "labels-left", "colon-labels", "toolbar"]
      },
      {
        "name": "CWF.Request Type List",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_RequestType",
        "type": "list",
        "properties": [
          "RequestTypeId",
          "RequestTypeCode",
          "RequestTypeName",
          "DefaultSlaHours",
          "RequiresAmount",
          "IsActive"
        ],
        "methods": [],
        "defaultListMethod": "List",
        "area": "admin",
        "options": ["toolbar"]
      },
      {
        "name": "CWF.Request Priority Editor",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_RequestPriority",
        "type": "capture",
        "properties": ["PriorityCode", "PriorityName", "SortOrder", "IsActive"],
        "methods": ["Create", "Read", "Update", "Delete"],
        "area": "admin",
        "options": ["editable", "labels-left", "colon-labels", "toolbar"]
      },
      {
        "name": "CWF.Request Priority List",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_RequestPriority",
        "type": "list",
        "properties": ["PriorityCode", "PriorityName", "SortOrder", "IsActive"],
        "methods": [],
        "defaultListMethod": "List",
        "area": "admin",
        "options": ["toolbar"]
      },
      {
        "name": "CWF.Approval Matrix Rule Editor",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_RequestApprovalMatrix",
        "type": "capture",
        "properties": [
          "RuleId",
          "MatrixCode",
          "RuleKey",
          "StageNumber",
          "MinAmount",
          "MaxAmount",
          "Priority",
          "DepartmentId",
          "ApproverType",
          "ApproverValue",
          "ApproverLabel",
          "IsActive"
        ],
        "methods": ["Create", "Read", "Update", "Delete"],
        "lookupControls": [
          { "property": "DepartmentId", "lookup": "Department", "allowEmptySelection": true }
        ],
        "area": "admin",
        "options": ["editable", "labels-left", "colon-labels", "toolbar"]
      },
      {
        "name": "CWF.Approval Matrix Rule List",
        "smartObject": "CWF_CorporateWorkflowTest_CWF_RequestApprovalMatrix",
        "type": "list",
        "properties": [
          "RuleId",
          "MatrixCode",
          "RuleKey",
          "StageNumber",
          "MinAmount",
          "MaxAmount",
          "DepartmentId",
          "ApproverLabel",
          "ApproverType",
          "ApproverValue",
          "Priority",
          "IsActive"
        ],
        "methods": [],
        "defaultListMethod": "List",
        "area": "admin",
        "options": ["toolbar"]
      }
    ],
    "forms": [
      {
        "name": "CWF.Request Management",
        "views": ["CWF.Request Editor", "CWF.Request List"],
        "viewTitles": {
          "CWF.Request Editor": "Request Details",
          "CWF.Request List": "Requests"
        },
        "tabs": [
          { "name": "Requests", "views": ["CWF.Request List"] },
          { "name": "Request Details", "views": ["CWF.Request Editor"] },
          {
            "name": "My Tasks",
            "worklist": {
              "rows": 20,
              "refreshIntervalSeconds": 300,
              "showToolbar": true,
              "showFilter": true,
              "showSearch": false,
              "enableSearch": true,
              "height": "445px",
              "openTaskInNewWindow": true,
              "actions": ["viewWorkflow", "sleep", "redirect", "release", "share"]
            }
          }
        ],
        "options": [],
        "behaviors": ["load-form-list-click", "refresh-list-form-submit", "refresh-list-form-load"]
      },
      {
        "name": "CWF.Approval Task Management",
        "views": ["CWF.Approval Task Editor", "CWF.Approval Task List"],
        "viewTitles": {
          "CWF.Approval Task Editor": "Task Details",
          "CWF.Approval Task List": "Approval Tasks"
        },
        "tabs": [
          { "name": "Tasks", "views": ["CWF.Approval Task List"] },
          { "name": "Task Details", "views": ["CWF.Approval Task Editor"] }
        ],
        "options": [],
        "behaviors": ["load-form-list-click", "refresh-list-form-submit", "refresh-list-form-load"]
      },
      {
        "name": "CWF.Request Type Administration",
        "views": ["CWF.Request Type Editor", "CWF.Request Type List"],
        "viewTitles": {
          "CWF.Request Type Editor": "Request Type Details",
          "CWF.Request Type List": "Request Types"
        },
        "area": "admin",
        "options": ["no-tabs"],
        "behaviors": ["load-form-list-click", "refresh-list-form-submit", "refresh-list-form-load"]
      },
      {
        "name": "CWF.Request Priority Administration",
        "views": ["CWF.Request Priority Editor", "CWF.Request Priority List"],
        "viewTitles": {
          "CWF.Request Priority Editor": "Priority Details",
          "CWF.Request Priority List": "Request Priorities"
        },
        "area": "admin",
        "options": ["no-tabs"],
        "behaviors": ["load-form-list-click", "refresh-list-form-submit", "refresh-list-form-load"]
      },
      {
        "name": "CWF.Approval Matrix Administration",
        "views": ["CWF.Approval Matrix Rule Editor", "CWF.Approval Matrix Rule List"],
        "viewTitles": {
          "CWF.Approval Matrix Rule Editor": "Approval Rule Details",
          "CWF.Approval Matrix Rule List": "Approval Rules"
        },
        "area": "admin",
        "options": ["no-tabs"],
        "behaviors": ["load-form-list-click", "refresh-list-form-submit", "refresh-list-form-load"]
      }
    ]
  },
  "verification": {
    "expectedViews": [
      "CWF.Request Editor",
      "CWF.Request List",
      "CWF.Approval Task Editor",
      "CWF.Approval Task List",
      "CWF.Request Type Editor",
      "CWF.Request Type List",
      "CWF.Request Priority Editor",
      "CWF.Request Priority List",
      "CWF.Approval Matrix Rule Editor",
      "CWF.Approval Matrix Rule List"
    ],
    "expectedForms": [
      "CWF.Request Management",
      "CWF.Approval Task Management",
      "CWF.Request Type Administration",
      "CWF.Request Priority Administration",
      "CWF.Approval Matrix Administration"
    ],
    "smokeTestRuntime": true,
    "runtimeBaseUrl": "https://spk2.trials.demome.tech/Runtime"
  }
}
