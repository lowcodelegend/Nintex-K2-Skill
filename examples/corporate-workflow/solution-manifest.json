{
  "schemaVersion": 1,
  "shortCode": "CWF",
  "name": "CWF.Corporate Workflow",
  "application": {
    "rootCategoryPath": "K2 Skills\\CWF.Corporate Workflow"
  },
  "components": {
    "smartObjects": {
      "manifest": "manifest.json"
    },
    "forms": {
      "manifest": "smartforms-manifest.json",
      "dependsOn": ["smartObjects"]
    },
    "workflows": [
      {
        "name": "CWF.Request Approval",
        "manifest": "workflow-manifest.json",
        "dependsOn": ["smartObjects", "forms"]
      }
    ]
  },
  "policies": {
    "dataModelComplexity": "complex",
    "versionFreeNames": true,
    "modernForms": true,
    "workflowEntries": [
      {
        "workflow": "CWF.Request Approval",
        "form": "CWF.Request Management",
        "formOwnership": "dedicated",
        "startStateDefault": "auto"
      }
    ]
  },
  "verification": {
    "runtimeBaseUrl": "https://spk2.trials.demome.tech/Runtime",
    "scenarios": [
      {
        "name": "CWF.Submit and decide a corporate request",
        "entryForm": "CWF.Request Management",
        "steps": [
          "open the ordinary form URL without a state query parameter",
          "create a valid corporate request",
          "prove the request was saved and capture RequestId",
          "prove one CWF.Request Approval instance started for RequestId",
          "prove CWF.REQUEST selected the expected amount/department rule and assigned its K2 approver value",
          "select Approve and prove a second-stage rule is resolved when the threshold requires it, or select Reject",
          "prove WorkflowRequest.Status matches the selected outcome"
        ]
      }
    ]
  }
}
