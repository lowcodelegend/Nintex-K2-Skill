{
  "schemaVersion": 1,
  "name": "Corporate request approval workflow",
  "k2": {
    "designerHost": "smartforms",
    "host": "localhost",
    "port": 5555,
    "integrated": true,
    "securityLabel": "K2"
  },
  "application": { "rootCategoryPath": "K2 Skills\\Corporate Workflow" },
  "workflow": {
    "name": "CW Request Approval",
    "kind": "request-approval",
    "publish": true,
    "replaceExisting": true,
    "comment": "Request status, email, and approval task baseline",
    "requestStatusUpdate": {
      "name": "Set Pending Approval Status",
      "smartObject": "K2Skills_CorporateWorkflow_Test_app_WorkflowRequest",
      "method": "Update",
      "identifierProperty": "RequestId",
      "statusProperty": "Status",
      "statusValue": "Pending Approval",
      "approvedStatusValue": "Approved",
      "rejectedStatusValue": "Rejected"
    },
    "email": {
      "name": "Send Approval Notification",
      "from": "$environment:From Address",
      "to": ["$originator"],
      "subject": "Corporate request awaiting approval",
      "body": "A corporate workflow request is awaiting your approval.",
      "html": false
    },
    "userTask": {
      "name": "Review Corporate Request",
      "assignees": ["$originatorManager"],
      "instructions": "Review the corporate request and select an outcome.",
      "actions": ["Approve", "Reject"]
    },
    "smartForms": {
      "form": "CW Request Management",
      "startState": "CW Request Approval Start",
      "taskState": "CW Request Approval Task",
      "startRuleContains": "Create Button",
      "makeStartStateDefault": false,
      "workflowStripLocation": "bottom"
    }
  }
}
