{
  "schemaVersion": 1,
  "name": "SNC.Investigate stage",
  "k2": {
    "designerHost": "smartforms",
    "host": "localhost",
    "port": 5555,
    "integrated": true,
    "securityLabel": "K2"
  },
  "application": {
    "rootCategoryPath": "K2 Skills\\SNC.Supplier Nonconformance",
    "workflowCategoryName": "SNC.Supplier Nonconformance WFs"
  },
  "workflow": {
    "name": "SNC.Stage Investigate",
    "kind": "request-approval",
    "publish": true,
    "replaceExisting": true,
    "comment": "Reusable investigation stage",
    "requestStatusUpdate": {
      "name": "SNC.Record Investigation Result",
      "smartObject": "SNC_SupplierNonconformance_SNC_CaseStageInstance",
      "method": "Update",
      "identifierProperty": "CaseStageInstanceId",
      "identifierDataField": "CaseStageInstanceId",
      "statusProperty": "OutcomeCode",
      "statusValue": "PENDING",
      "approvedStatusValue": "EVIDENCE_COMPLETE",
      "rejectedStatusValue": "MORE_INFORMATION_REQUIRED"
    },
    "email": {
      "name": "SNC.Investigation assigned",
      "from": "$environment:From Address",
      "to": [
        "$originator"
      ],
      "subject": "Investigate supplier nonconformance",
      "body": "Gather evidence and corrective actions.",
      "html": false
    },
    "userTask": {
      "name": "SNC.Investigate Case",
      "assignees": [
        "$originator"
      ],
      "instructions": "Complete investigation and evidence collection.",
      "actions": [
        "Approve",
        "Reject"
      ],
      "formUrl": "https://spk2.trials.demome.tech/Runtime/Form/SNC.Supplier%20Nonconformance/",
      "requestIdParameter": "CaseStageInstanceId",
      "notification": {
        "enabled": true,
        "from": "$environment:From Address",
        "subject": "Investigation task",
        "body": "Investigate the supplier nonconformance. {{task.worklistLink}}",
        "richText": true
      }
    },
    "smartForms": {
      "form": "SNC.Stage Task",
      "startState": "SNC.Investigate Start",
      "taskState": "SNC.Investigate Task",
      "startRuleContains": "Create Button",
      "makeStartStateDefault": false,
      "workflowStripLocation": "bottom"
    }
  }
}
