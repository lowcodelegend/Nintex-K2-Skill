{
  "schemaVersion": 1,
  "name": "SNC.Resolve stage",
  "k2": {
    "designerHost": "smartforms",
    "host": "localhost",
    "port": 5555,
    "integrated": true,
    "securityLabel": "K2"
  },
  "application": {
    "rootCategoryPath": "K2 Skills\\SNC.Supplier Nonconformance",
    "workflowCategoryName": "SNC.Supplier Nonconformance WFs"
  },
  "workflow": {
    "name": "SNC.Stage Resolve",
    "kind": "request-approval",
    "publish": true,
    "replaceExisting": true,
    "comment": "Reusable resolution and communication stage",
    "requestStatusUpdate": {
      "name": "SNC.Record Resolution Result",
      "smartObject": "SNC_SupplierNonconformance_SNC_CaseStageInstance",
      "method": "Update",
      "identifierProperty": "CaseStageInstanceId",
      "identifierDataField": "CaseStageInstanceId",
      "statusProperty": "OutcomeCode",
      "statusValue": "PENDING",
      "approvedStatusValue": "RESOLUTION_COMPLETED",
      "rejectedStatusValue": "ACTION_FAILED"
    },
    "email": {
      "name": "SNC.Resolution assigned",
      "from": "$environment:From Address",
      "to": [
        "$originator"
      ],
      "subject": "Resolve supplier nonconformance",
      "body": "Implement and communicate the approved resolution.",
      "html": false
    },
    "userTask": {
      "name": "SNC.Resolve Case",
      "assignees": [
        "$originator"
      ],
      "instructions": "Implement the disposition and record communication.",
      "actions": [
        "Approve",
        "Reject"
      ],
      "formUrl": "https://spk2.trials.demome.tech/Runtime/Form/SNC.Supplier%20Nonconformance/",
      "requestIdParameter": "CaseStageInstanceId"
    },
    "smartForms": {
      "form": "SNC.Stage Task",
      "startState": "SNC.Resolve Start",
      "taskState": "SNC.Resolve Task",
      "startRuleContains": "Create Button",
      "makeStartStateDefault": false,
      "workflowStripLocation": "bottom"
    }
  }
}
