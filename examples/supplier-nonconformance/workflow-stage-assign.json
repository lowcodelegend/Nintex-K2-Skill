{
  "schemaVersion": 1,
  "name": "SNC.Assign stage",
  "k2": {
    "designerHost": "smartforms",
    "host": "localhost",
    "port": 5555,
    "integrated": true,
    "securityLabel": "K2"
  },
  "application": {
    "rootCategoryPath": "K2 Skills\\SNC.Supplier Nonconformance",
    "workflowCategoryName": "SNC.Supplier Nonconformance WFs"
  },
  "workflow": {
    "name": "SNC.Stage Assign",
    "kind": "request-approval",
    "publish": true,
    "replaceExisting": true,
    "comment": "Reusable assignment stage",
    "requestStatusUpdate": {
      "name": "SNC.Record Assignment Result",
      "smartObject": "SNC_SupplierNonconformance_SNC_CaseStageInstance",
      "method": "Update",
      "identifierProperty": "CaseStageInstanceId",
      "identifierDataField": "CaseStageInstanceId",
      "statusProperty": "OutcomeCode",
      "statusValue": "PENDING",
      "approvedStatusValue": "ASSIGNED",
      "rejectedStatusValue": "NO_ELIGIBLE_OWNER"
    },
    "email": {
      "name": "SNC.Assignment review",
      "from": "$environment:From Address",
      "to": [
        "$originator"
      ],
      "subject": "Assign supplier nonconformance",
      "body": "Select an eligible accountable owner.",
      "html": false
    },
    "userTask": {
      "name": "SNC.Assign Case",
      "assignees": [
        "$originator"
      ],
      "instructions": "Assign the case using skills, workload and conflict rules.",
      "actions": [
        "Approve",
        "Reject"
      ],
      "formUrl": "https://spk2.trials.demome.tech/Runtime/Form/SNC.Supplier%20Nonconformance/",
      "requestIdParameter": "CaseStageInstanceId"
    },
    "smartForms": {
      "form": "SNC.Stage Task",
      "startState": "SNC.Assign Start",
      "taskState": "SNC.Assign Task",
      "startRuleContains": "Create Button",
      "makeStartStateDefault": false,
      "workflowStripLocation": "bottom"
    }
  }
}
