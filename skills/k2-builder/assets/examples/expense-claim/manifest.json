{
  "name": "EXP.Expense Claims Data",
  "application": { "rootCategoryPath": "K2 Skills\\EXP.Expense Claims" },
  "database": {
    "server": "localhost",
    "name": "EXP.ExpenseClaims",
    "integratedSecurity": true,
    "createIfMissing": true,
    "runtimePrincipal": "TRIALS\\k2svc",
    "scripts": ["sql/001_expense_claim.sql"]
  },
  "k2": {
    "host": "localhost",
    "port": 5555,
    "integrated": true,
    "securityLabel": "K2",
