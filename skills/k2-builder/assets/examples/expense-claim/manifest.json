    "queries": [{ "name": "expense category seed", "sql": "SELECT COUNT(*) FROM EXP.ExpenseCategory", "expectedScalar": "4" }],
    "smartObjectServiceObjects": ["EXP-ExpenseCategory", "EXP-ExpenseClaim", "EXP-ExpenseLine", "EXP-ExpenseClaimSummary"],
