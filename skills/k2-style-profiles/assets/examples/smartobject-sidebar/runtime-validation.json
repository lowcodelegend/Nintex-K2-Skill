{
  "schemaVersion": 1,
  "runtimeBaseUrl": "https://k2.example.com/Runtime",
  "designerUrl": "https://k2.example.com/Designer/",
  "trustedAuthHost": "k2.example.com",
  "assetUrls": {
    "criticalCss": "https://k2.example.com/APPAssets/sidebar-critical.min.css",
    "applicationCss": "https://k2.example.com/APPAssets/sidebar-application.min.css",
    "bootJavaScript": "https://k2.example.com/APPAssets/sidebar-shell.min.js"
  },
  "startForm": {
    "name": "APP.Home",
    "title": "APP.Home"
  },
  "transitionForm": {
    "name": "APP.My Work",
    "title": "APP.My Work",
    "navigationCode": "MY_WORK"
  },
  "selectors": {
    "shell": "#k2sp-shell",
    "route": "[data-k2sp-route]",
    "activeRoute": "[data-k2sp-route][aria-current=\"page\"]",
    "nativeNavigationTitle": "[data-sf-title=\"Application navigation\"]",
    "transition": ".k2sp-transition"
  },
  "stateObject": "__k2spSidebarBoot",
  "readyClass": "k2sp-ready",
  "leavingClass": "k2sp-leaving",
  "runtimeRootClass": "k2sp-runtime",
  "cacheVersionKey": "k2sp:navigation:version",
  "bootTimeoutMilliseconds": 2500,
  "requireCompression": true,
  "requireCacheHeaders": true
}
